# Required for reproducible installs (CI runs `npm ci` and will fail without it):
# @lobehub/icons declares peerDependencies on @lobehub/ui and antd that this app
# never imports — auto-installing them would drag all of antd into the tree and
# conflict with React 19 (@emoji-mart/react). The lockfile is generated with
# this flag on, so every environment must install with it too.
legacy-peer-deps=true
